# Foundry deploy config for Base Sepolia (chain id 84532)
# Copy to contracts/.env and fill in. NEVER commit the real .env.

# RPC endpoint for Base Sepolia
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Deployer private key (0x-prefixed). Use a throwaway testnet key.
PRIVATE_KEY=0x...

# Optional: for `forge verify-contract` on Sepolia Basescan
BASESCAN_API_KEY=
