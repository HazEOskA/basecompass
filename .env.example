# Frontend chain config (Vite). Copy to .env.local for local dev.

# Target chain id: 84532 = Base Sepolia (testnet), 8453 = Base mainnet.
VITE_CHAIN_ID=84532

# RPC endpoint for the target chain (optional; falls back to the public RPC).
VITE_BASE_RPC_URL=https://sepolia.base.org

# Address of the deployed BaseCompassCheckIn contract (set after deploying).
VITE_BASECOMPASS_CHECKIN_ADDRESS=
